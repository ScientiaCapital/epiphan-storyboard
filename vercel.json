{
  "version": 2,
  "builds": [
    {
      "src": "src/api.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 300,
        "memory": 2048
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "src/api.py"
    }
  ]
}
