# ===========================================
# Conductor-AI Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Supabase (Required for persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Redis (Required for job state)
REDIS_URL=redis://localhost:6379

# ===========================================
# LLM Providers (NO OpenAI)
# ===========================================
ANTHROPIC_API_KEY=sk-ant-...        # Claude models (direct API)
GOOGLE_API_KEY=AIza...              # Gemini models (direct API)
OPENROUTER_API_KEY=sk-or-...        # DeepSeek/Qwen/Gemini via OpenRouter

# ===========================================
# Stripe Billing (Phase 11)
# ===========================================
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products/prices in Stripe Dashboard
# Basic tier: $49/mo subscription
STRIPE_PRICE_ID_BASIC=price_...
# Pro tier: $199/mo subscription
STRIPE_PRICE_ID_PRO=price_...

# ===========================================
# Voice Synthesis (Cartesia)
# ===========================================
CARTESIA_API_KEY=...                # Sonic-3 TTS (40ms latency)

# ===========================================
# Screen Recording (Phase 9.0)
# ===========================================
BROWSERBASE_API_KEY=bb_live_...     # Cloud browser sessions
BROWSERBASE_PROJECT_ID=proj_...     # Recording project ID
RUNWAY_API_KEY=key_...              # Gen-3 Alpha video generation

# ===========================================
# Data Ingestion (Knowledge Brain)
# ===========================================
CLOSE_API_KEY=...                   # Close CRM calls/notes
LOOM_API_KEY=...                    # Video analytics

# ===========================================
# App Config
# ===========================================
APP_ENV=development
API_URL=http://localhost:8000
